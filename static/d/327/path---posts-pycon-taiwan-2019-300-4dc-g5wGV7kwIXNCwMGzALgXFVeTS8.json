64,'); background-size: cover; display: block;\"\n  ></span>\n  <img\n        class=\"gatsby-resp-image-image\"\n        alt=\"pycon taiwan 2019 8\"\n        title=\"pycon taiwan 2019 8\"\n        src=\"/static/0f67d7c132ffb322ff78a24d16863dbb/55071/pycon-taiwan-2019-8.jpg\"\n        srcset=\"/static/0f67d7c132ffb322ff78a24d16863dbb/493b1/pycon-taiwan-2019-8.jpg 163w,\n/static/0f67d7c132ffb322ff78a24d16863dbb/17f95/pycon-taiwan-2019-8.jpg 325w,\n/static/0f67d7c132ffb322ff78a24d16863dbb/55071/pycon-taiwan-2019-8.jpg 650w,\n/static/0f67d7c132ffb322ff78a24d16863dbb/4194c/pycon-taiwan-2019-8.jpg 975w,\n/static/0f67d7c132ffb322ff78a24d16863dbb/7b0d7/pycon-taiwan-2019-8.jpg 1280w\"\n        sizes=\"(max-width: 650px) 100vw, 650px\"\n        loading=\"lazy\"\n      />\n  </a>\n    </span></p>\n<hr>\n<h3><a href=\"https://mopcon.org/2019/\">2019 MOPCON</a> 開箱</h3>\n<p><span\n      class=\"gatsby-resp-image-wrapper\"\n      style=\"position: relative; display: block; margin-left: auto; margin-right: auto;  max-width: 650px;\"\n    >\n      <a\n    class=\"gatsby-resp-image-link\"\n    href=\"/static/0e0dcf22261a7a0eb4fc8ec221c9348d/7b0d7/pycon-taiwan-2019-9.jpg\"\n    style=\"display: block\"\n    target=\"_blank\"\n    rel=\"noopener\"\n  >\n    <span\n    class=\"gatsby-resp-image-background-image\"\n    style=\"padding-bottom: 75%; position: relative; bottom: 0; left: 0; background-image: url('data:image/jpeg;base64,'); background-size: cover; display: block;\"\n  ></span>\n  <img\n        class=\"gatsby-resp-image-image\"\n        alt=\"pycon taiwan 2019 9\"\n        title=\"pycon taiwan 2019 9\"\n        src=\"/static/0e0dcf22261a7a0eb4fc8ec221c9348d/55071/pycon-taiwan-2019-9.jpg\"\n        srcset=\"/static/0e0dcf22261a7a0eb4fc8ec221c9348d/493b1/pycon-taiwan-2019-9.jpg 163w,\n/static/0e0dcf22261a7a0eb4fc8ec221c9348d/17f95/pycon-taiwan-2019-9.jpg 325w,\n/static/0e0dcf22261a7a0eb4fc8ec221c9348d/55071/pycon-taiwan-2019-9.jpg 650w,\n/static/0e0dcf22261a7a0eb4fc8ec221c9348d/4194c/pycon-taiwan-2019-9.jpg 975w,\n/static/0e0dcf22261a7a0eb4fc8ec221c9348d/7b0d7/pycon-taiwan-2019-9.jpg 1280w\"\n        sizes=\"(max-width: 650px) 100vw, 650px\"\n        loading=\"lazy\"\n      />\n  </a>\n    </span></p>\n<hr>\n<p>這次最令人印象深刻的就是 Unnotech 的<a href=\"https://pycon.unnotech.com/\">挑戰賽</a>，議程中一堆人畫面都是這個…</p>\n<p>不得不說他們真的蠻用心準備的！</p>\n<h3>Unnotech Python Challenge</h3>\n<p><span\n      class=\"gatsby-resp-image-wrapper\"\n      style=\"position: relative; display: block; margin-left: auto; margin-right: auto;  max-width: 650px;\"\n    >\n      <a\n    class=\"gatsby-resp-image-link\"\n    href=\"/static/da1ec76e872f17d8581fd82112772dd3/01305/pycon-taiwan-2019-10.jpg\"\n    style=\"display: block\"\n    target=\"_blank\"\n    rel=\"noopener\"\n  >\n    <span\n    class=\"gatsby-resp-image-background-image\"\n    style=\"padding-bottom: 67.80202235231506%; position: relative; bottom: 0; left: 0; background-image: url('data:image/jpeg;base64,'); background-size: cover; display: block;\"\n  ></span>\n  <img\n        class=\"gatsby-resp-image-image\"\n        alt=\"pycon taiwan 2019 10\"\n        title=\"pycon taiwan 2019 10\"\n        src=\"/static/da1ec76e872f17d8581fd82112772dd3/55071/pycon-taiwan-2019-10.jpg\"\n        srcset=\"/static/da1ec76e872f17d8581fd82112772dd3/493b1/pycon-taiwan-2019-10.jpg 163w,\n/static/da1ec76e872f17d8581fd82112772dd3/17f95/pycon-taiwan-2019-10.jpg 325w,\n/static/da1ec76e872f17d8581fd82112772dd3/55071/pycon-taiwan-2019-10.jpg 650w,\n/static/da1ec76e872f17d8581fd82112772dd3/4194c/pycon-taiwan-2019-10.jpg 975w,\n/static/da1ec76e872f17d8581fd82112772dd3/a7e6c/pycon-taiwan-2019-10.jpg 1300w,\n/static/da1ec76e872f17d8581fd82112772dd3/01305/pycon-taiwan-2019-10.jpg 1879w\"\n        sizes=\"(max-width: 650px) 100vw, 650px\"\n        loading=\"lazy\"\n      />\n  </a>\n    </span></p>\n<p>這次聽到蠻多元的主題，Data Pipeline、Deep Learning、Statistics、Profiling、GraphQL、Bot、Asynchronous I/O…等。</p>\n<p>PyCon 真的辦的超讚，有機會一定還要來參加，雖然說票也不便宜就是了 XD</p>\n<p><strong>Do you know PyCon Japan?</strong></p>","frontmatter":{"title":"PyCon Taiwan 2019","date":"September 26, 2019"}}},"pageContext":{"slug":"/pycon-taiwan-2019/","previous":{"fields":{"slug":"/datacon-2019/"},"frontmatter":{"title":"DataCon.TW 2019"}},"next":{"fields":{"slug":"/cli-log-parsing-cool/"},"frontmatter":{"title":"面對 Log 檔的思路"}}}}